# Data Collector Web Service — environment configuration

# Service identity
APP_NAME=data-collector-webservice
APP_ENV=dev
LOG_LEVEL=INFO

# Validation behavior
# When true, missing common identity fields (e.g. node_fqdn) cause HTTP 422.
# When false, weak records are accepted (HTTP 200) and quarantined for review.
STRICT_VALIDATION=false

# ── Output sinks ─────────────────────────────────────────────────────────────
# Comma-separated: "staging" and/or "jsonl".
#   staging → write {meta,data} files into the NFS pending/ dir for the Airflow
#             generic_postgres_writer DAG (production; safe with many replicas).
#   jsonl   → append to a single local JSONL file (single-node/dev only).
OUTPUT_SINKS=staging

# NFS root shared with Airflow. The webservice writes into
# "<STAGING_FOLDER_PATH>/<PENDING_DIRNAME>", which MUST be the same physical NFS
# directory the Airflow generic_postgres_writer scans (its staging_folder_path
# Variable). In Kubernetes this is a ReadWriteMany NFS PVC mounted here.
STAGING_FOLDER_PATH=/nfs/airflow-staging
PENDING_DIRNAME=pending

# Local audit storage (one file per request → safe across replicas)
RAW_PAYLOAD_DIR=/var/lib/data-collector/raw
QUARANTINE_DIR=/var/lib/data-collector/quarantine
# Only used when OUTPUT_SINKS contains "jsonl"
NORMALIZED_JSONL_PATH=/var/lib/data-collector/normalized/metrics.jsonl

# Inbound request size limit (10 MiB by default)
MAX_BODY_BYTES=10485760

# ── Proxy / mTLS trust model ─────────────────────────────────────────────────
# Set to true in production behind a proxy/Ingress that injects X-SSL-* headers.
TRUST_PROXY_CERT_HEADERS=true
# When true, requests are rejected unless X-SSL-Client-Verify == SUCCESS.
ENFORCE_PROXY_MTLS_HEADER=false
# Headers used by the trusted reverse proxy to forward mTLS metadata.
CLIENT_CERT_VERIFY_HEADER=X-SSL-Client-Verify
CLIENT_CERT_SUBJECT_HEADER=X-SSL-Client-Subject
CLIENT_CERT_ISSUER_HEADER=X-SSL-Client-Issuer
CLIENT_CERT_FINGERPRINT_HEADER=X-SSL-Client-Fingerprint

# Optional allowlist; comma-separated. If set, the proxy-provided subject DN
# (or fingerprint) must contain one of these values.
ALLOWED_CLIENT_CERT_SUBJECTS=
ALLOWED_CLIENT_CERT_FINGERPRINTS=
